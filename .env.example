# .env (DO NOT COMMIT THIS FILE TO GITHUB)
# Django Settings
DEBUG=False
SECRET_KEY=your-very-secure-random-secret-key
ALLOWED_HOSTS=.pythonanywhere.com,localhost,127.0.0.1

# Supabase Database Settings
# Find this in Supabase Project Settings -> Database -> Connection String (URI)
# Make sure to replace [YOUR-PASSWORD] with the actual password!
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# GitHub Settings (for file handling)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=yourusername/yourreponame
